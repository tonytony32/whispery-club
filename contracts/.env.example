# RPC endpoint — get a free key at https://alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Alice's private key (deployer + admin) — never commit the real value
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
DEPLOYER_ADDRESS=0xALICE_PUBLIC_ADDRESS

# Founding members (public addresses, no private keys needed)
ALICE=0xALICE_PUBLIC_ADDRESS
BOB=0xBOB_PUBLIC_ADDRESS
CHARLIE=0xCHARLIE_PUBLIC_ADDRESS

# Get a free key at https://etherscan.io/myapikey (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
